# PROCESOS SIGET
# ==============================

p1 = Proceso("P1 - Trafico rutinario", 6, 3, 500)
p2 = Proceso("P2 - Accidente vial", 4, 1, 200)
p3 = Proceso("P3 - Reporte estadistico", 8, 2, 700)

procesos = [p1, p2, p3]

round_robin(procesos.copy(), quantum=2)

p1 = Proceso("P1 - Trafico rutinario", 6, 3, 500)
