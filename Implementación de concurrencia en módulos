import threading
import time
import random
from threading import Semaphore

buffer = []

empty = Semaphore(5)   
full = Semaphore(0)    
mutex = Semaphore(1)   

def productor(nombre):

    for i in range(5):

        dato = random.randint(1,100)

        empty.acquire()
        mutex.acquire()

        buffer.append(dato)
        print(nombre,"envía dato de tráfico:", dato)

        mutex.release()
        full.release()

        time.sleep(random.randint(1,2))

def consumidor():

    for i in range(10):

        full.acquire()
        mutex.acquire()

        dato = buffer.pop(0)
        print("Analizador procesa dato:", dato)

        mutex.release()
        empty.release()

        time.sleep(1)

sensor1 = threading.Thread(target=productor,args=("Sensor 1",))
sensor2 = threading.Thread(target=productor,args=("Sensor 2",))
analizador = threading.Thread(target=consumidor)

sensor1.start()
sensor2.start()
analizador.start()

sensor1.join()
sensor2.join()
analizador.join()

print("Simulación finalizada")
